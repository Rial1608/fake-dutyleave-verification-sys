# Fake DL System - Environment Configuration
# Copy this file to .env and update the values as needed

# Port for the Fake DL System
# Run multiple systems on different ports:
#   Fake DL System: 3000
#   Attendance System: 3001
PORT=3000

# Session secret for securing session data
SESSION_SECRET=fake-dl-sys-secret-key-2024

# Google Maps API Key for location services
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# MongoDB Atlas — shared database with Attendance System
# Both systems use the same 'attendance_system' database for cross-verification
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/attendance_system?retryWrites=true&w=majority

# Verification config — max distance (km) for GPS location match
MAX_DISTANCE_KM=0.1

# API Base Route
# This system uses /api/dl as the base route for all API endpoints
# Example endpoints:
#   - http://localhost:3000/api/dl/auth/login
#   - http://localhost:3000/api/dl/student/dashboard
#   - http://localhost:3000/api/dl/admin/requests
