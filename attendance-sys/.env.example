# Attendance System - Environment Configuration
# Copy this file to .env and update the values as needed

# Port for the Attendance System
# Run on different port from Fake DL System
# Fake DL: 3000, Attendance: 3001
PORT=3001

# Session secret for securing session data
SESSION_SECRET=attendance-sys-secret-key-2024

# Database
# Database is stored in ./database/attendance_sys.db (auto-created)

# API Base Route
# This system uses /api/attendance as the base route for all API endpoints
# Example endpoints:
#   - http://localhost:3001/api/attendance/events
#   - http://localhost:3001/api/attendance/attendance/:studentId
#   - http://localhost:3001/api/attendance/check-in
#   - http://localhost:3001/api/attendance/check-out
